[
  {
    "name": "theme_info",
    "theme_name": "CopyshopIA Theme",
    "theme_author": "Copyshop IA",
    "theme_version": "1",
    "theme_documentation_url": "",
    "theme_support_url": ""
  },
  {
    "name": "Apparence et espacement",
    "settings": [
      {
        "type": "paragraph",
        "content": "Adaptez le thème à votre style de marque en modifiant les éléments arrondis, l'espacement et le style des icônes."
      },
      {
        "type": "range",
        "id": "page_width",
        "min": 1300,
        "max": 1800,
        "step": 20,
        "unit": "px",
        "label": "Largeur de la page",
        "default": 1600
      },
      {
        "type": "header",
        "content": "Espacement des sections"
      },
      {
        "type": "select",
        "id": "section_vertical_spacing",
        "label": "Espace vertical entre les sections",
        "options": [
          { "value": "xsmall", "label": "Très petit" },
          { "value": "small", "label": "Petit" },
          { "value": "medium", "label": "Moyen" },
          { "value": "large", "label": "Grand" }
        ],
        "default": "medium"
      },
      {
        "type": "select",
        "id": "section_boxed_horizontal_spacing",
        "label": "Espace horizontal à l'intérieur des sections",
        "options": [
          { "value": "xsmall", "label": "Très petit" },
          { "value": "small", "label": "Petit" },
          { "value": "medium", "label": "Moyen" },
          { "value": "large", "label": "Grand" }
        ],
        "default": "medium"
      },
      {
        "type": "header",
        "content": "Arrondis"
      },
      {
        "type": "range",
        "id": "button_border_radius",
        "min": 0,
        "max": 60,
        "step": 2,
        "unit": "px",
        "label": "Rayon des coins du bouton",
        "default": 0
      },
      {
        "type": "range",
        "id": "input_border_radius",
        "min": 0,
        "max": 10,
        "step": 2,
        "unit": "px",
        "label": "Rayon des coins du champ de saisie",
        "default": 0
      },
      {
        "type": "range",
        "id": "block_border_radius",
        "min": 0,
        "max": 64,
        "step": 4,
        "unit": "px",
        "label": "Rayon des coins du bloc",
        "default": 0
      },
      {
        "type": "header",
        "content": "Ombre"
      },
      {
        "type": "range",
        "id": "block_shadow_opacity",
        "min": 0,
        "max": 100,
        "unit": "%",
        "label": "Opacité",
        "default": 0
      },
      {
        "type": "range",
        "id": "block_shadow_horizontal_offset",
        "min": -32,
        "max": 32,
        "step": 2,
        "unit": "px",
        "label": "Décalage horizontal",
        "default": 0
      },
      {
        "type": "range",
        "id": "block_shadow_vertical_offset",
        "min": -32,
        "max": 32,
        "step": 2,
        "unit": "px",
        "label": "Décalage vertical",
        "default": 0
      },
      {
        "type": "range",
        "id": "block_shadow_blur",
        "min": 0,
        "max": 60,
        "step": 5,
        "unit": "px",
        "label": "Flou",
        "default": 50
      },
      {
        "type": "header",
        "content": "Icône"
      },
      {
        "type": "range",
        "id": "icon_stroke_width",
        "min": 1,
        "max": 2,
        "step": 0.1,
        "unit": "px",
        "label": "Épaisseur de l'icône",
        "default": 2
      },
      {
        "type": "select",
        "id": "icon_style",
        "label": "Style de l'icône",
        "info": "Toutes les icônes ne possèdent pas un style duo-ton.",
        "options": [
          { "value": "mono", "label": "Monochrome" },
          { "value": "duo", "label": "Duo-tone" }
        ],
        "default": "duo"
      },
      {
        "type": "header",
        "content": "Bouton"
      },
      {
        "type": "select",
        "id": "button_style",
        "label": "Style du bouton",
        "options": [
          { "value": "fill", "label": "Remplir" },
          { "value": "outline", "label": "Contour" }
        ],
        "default": "fill"
      },
      {
        "type": "select",
        "id": "button_hover_effect",
        "label": "Effet au survol",
        "info": "L'effet au survol n'est pas disponible sur les appareils tactiles (téléphone, tablette...).",
        "options": [
          { "value": "none", "label": "Aucun" },
          { "value": "fade", "label": "Fondu" },
          { "value": "reverse", "label": "Style inversé" }
        ],
        "default": "fade"
      }
    ]
  },
