ctor","buy_buttons","4b829a21-7f86-4459-af48-c77dfbca8461","ae3a4517-50b2-4eba-a04f-c8c064aebce8","005c7807-7ffc-4837-b77b-59856ca6b942"],"settings":{"full_width":true,"show_fixed_add_to_cart":true,"desktop_media_width":55,"desktop_media_layout":"grid_highlight","mobile_media_size":"expanded","mobile_carousel_control":"floating_dots","enable_video_autoplay":false,"enable_video_looping":true,"enable_image_zoom":true,"max_image_zoom_level":3,"background":"","background_gradient":"","text_color":"","input_background":"rgba(0,0,0,0)","input_text_color":""}},"02fc6cd0-f691-45c5-8ffa-be93bf92c4a5":{"type":"accordion-content","blocks":{"template--17885942513959__02fc6cd0-f691-45c5-8ffa-be93bf92c4a5-1676466583c542cb2e-0":{"type":"item","settings":{"title":"Description","content":"<p>Nous avons entrepris de créer un fauteuil qui établit une nouvelle norme industrielle en matière de design et de confort, mais qui coûte la moitié du prix de ses homologues. Conçue en Californie, la chaise Verve est conçue de main de maître et fabriquée de manière obsessionnelle, en mettant l'accent sur une esthétique attrayante, une ergonomie et une valeur exceptionnelles.<br\/><br\/>Enveloppé dans un tricot 3D unique, son dossier suspendu en forme de V offre un soutien intégré et réglable de la colonne vertébrale pour un confort continu. La correspondance précise des couleurs entre les matériaux produit une palette véritablement unifiée qui permet à quiconque de créer des lignes de vue accrocheuses à la maison ou au travail.<\/p>"}},"template--17885942513959__02fc6cd0-f691-45c5-8ffa-be93bf92c4a5-1676466583c542cb2e-1":{"type":"item","settings":{"title":"Dimensions","content":"<p>Dans l'ensemble :<br\/><br\/>27\" W x 27\" D x 37-41\" H P x 37-41\" H<br\/>Poids assemblé : 26 lbs<br\/>Capacité maximale : 300 lbs<br\/><br\/>Réglages :<br\/><br\/>Inclinaison de 20° de la chaise<br\/>5 cycles de tension d'inclinaison<br\/>Plage d'appui lombaire de 2<br\/>Profondeur du siège de 2,5 po<br\/>Hauteur de l'accoudoir : 2,5<br\/><br\/>Matériaux :<br\/><br\/>Tissu : Tricot 3D, 100% polyester<br\/>Assise : mousse moulée haute densité<br\/>Base : Aluminium revêtu de poudre<br\/>Cadre : Polyamide renforcé de verre<\/p>"}},"template--17885942513959__02fc6cd0-f691-45c5-8ffa-be93bf92c4a5-1676466583c542cb2e-2":{"type":"item","settings":{"title":"Détails","content":"<p>Expédition et assemblage :<br\/><br\/>Expédition : La chaise Verve est expédiée gratuitement avec un auto-assemblage facile.<br\/>Montage : Voir les instructions de montage <em><strong>ici<\/strong><\/em>.<br\/><br\/>Politique de retour :<br\/><br\/>Si vous souhaitez procéder à un retour, les produits Branch comme neufs dans leur emballage d'origine peuvent être retournés pour un remboursement dans les <strong>30 jours suivant la livraison<\/strong>. Notre politique complète se trouve <em><strong>ici<\/strong><\/em>.<br\/><br\/>Garantie :<br\/><br\/>La chaise Verve est couverte par une garantie de 10 ans. Notre politique complète peut être consultée <em><strong>ici<\/strong><\/em>.<\/p>"}}},"block_order":["template--17885942513959__02fc6cd0-f691-45c5-8ffa-be93bf92c4a5-1676466583c542cb2e-0","template--17885942513959__02fc6cd0-f691-45c5-8ffa-be93bf92c4a5-1676466583c542cb2e-1","template--17885942513959__02fc6cd0-f691-45c5-8ffa-be93bf92c4a5-1676466583c542cb2e-2"],"settings":{"full_width":true,"subheading":"","title":"Quelques infos","content":"","button_text":"","button_url":"","text_position":"center","background":"#33463a","background_gradient":"","text_color":"#ffffff","heading_color":"","heading_gradient":"","button_background":"","button_text_color":"","accordion_background":"#ffffff","accordion_text_color":"#000000"}},"a9ee1872-e8aa-44e9-9d56-7836d13b8373":{"type":"slideshow","blocks":{"template--17863951647015__a9ee1872-e8aa-44e9-9d56-7836d13b8373-16763939530689c9e2-0":{"type":"image","settings":{"image":"shopify:\/\/shop_images\/Capture_d_ecran_2023-02-14_a_18.00.45.png","mobile_image":"shopify:\/\/shop_imag