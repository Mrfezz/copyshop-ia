<privacy-bar class="privacy-bar" hidden>
  <div class="privacy-bar__inner">
    <button type="button" class="privacy-bar__close" data-action="close">
      <span class="sr-only">{{ 'general.accessibility.close' | t }}</span>
      {%- render 'icon' with 'delete' -%}
    </button>

    <div class="v-stack gap-4">
      <div class="v-stack gap-2">
        {%- if section.settings.privacy_bar_title != blank -%}
          <p class="bold">{{ section.settings.privacy_bar_title | escape }}</p>
        {%- endif -%}

        {%- if section.settings.privacy_bar_content != blank -%}
          <div class="prose text-xs">
            {{- section.settings.privacy_bar_content -}}
          </div>
        {%- endif -%}
      </div>

      <div class="h-stack gap-2">
        <button type="button" class="button button--sm" data-action="accept">{{ 'general.privacy_bar.accept' | t }}</button>
        <button type="button" class="button button--sm button--subdued" data-action="decline">{{ 'general.privacy_bar.decline' | t }}</button>
      </div>
    </div>
  </div>
</privacy-bar>

{% schema %}
{
  "name": "Cookies",
  "class": "shopify-section--privacy-banner",
  "settings": [
    {
      "type": "paragraph",
      "content": "La bannière de confidentialité sera visible uniquement si elle respecte les conditions de l'[API de confidentialité de Shopify](https://shopify.dev/docs/themes/consent-tracking-api) ou dans l'éditeur de thème pour faciliter les modifications."
    },
    {
      "type": "text",
      "id": "privacy_bar_title",
      "label": "Titre",
      "default": "Politique des cookies"
    },
    {
      "type": "richtext",
      "id": "privacy_bar_content",
      "label": "Contenu",
      "default": "<p>Nous utilisons des cookies et des technologies similaires pour vous offrir la meilleure expérience possible sur notre site. Consultez notre politique de confidentialité pour plus d'informations.</p>"
    }
  ]
}
{% endschema %}
